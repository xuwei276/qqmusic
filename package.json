{
  "name": "qq-music-login-search-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pinyin-pro": "^3.28.1"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.local.qqmusic.karaoke",
    "productName": "QQ Music Karaoke",
    "directories": {
      "output": "dist"
    },
    "files": [
      "certs/**",
      "electron/**",
      "public/**",
      "server.js",
      "package.json",
      "node_modules/**"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
